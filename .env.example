# Public browser configuration. Never place secrets in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_APP_NAME=TERRAST Sustainability Disclosure Hub
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_SUPABASE_URL=
# Prefer the current Supabase publishable key. The legacy anon variable remains
# for deployments whose application code still expects it during migration.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase administration. Prefer the current independently
# rotatable secret key; the legacy service-role variable is a compatibility
# fallback during migration. Never expose or log either value.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only AI configuration. Leave blank for deterministic demo output.
OPENAI_API_KEY=
OPENAI_MODEL=

# TERRAST mode is reserved for the future server command. The current Sync UI
# always selects Mock explicitly; API mode must remain disabled until contract approval.
TERRAST_CONNECTOR_MODE=mock
TERRAST_API_BASE_URL=
TERRAST_API_KEY=

# AI route controls (the in-memory limiter is demo-only; production needs a
# distributed limiter/WAF).
API_RATE_LIMIT_REQUESTS=10
API_RATE_LIMIT_WINDOW_SECONDS=60

# Reserved production controls. Evidence signed-URL/upload commands are not yet wired.
EVIDENCE_SIGNED_URL_TTL_SECONDS=300
EVIDENCE_MAX_FILE_BYTES=20971520
